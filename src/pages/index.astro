---
import SitePage from '../components/SitePage';
import '../styles/global.css';

const pageTitle = 'Bao Zixuan | Reverieach';
const pageDescription =
  'Personal homepage of Bao Zixuan, an AI student at Beijing University of Posts and Telecommunications, building AI tools, desktop utilities, and embedded systems.';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#f8f8f0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <SitePage page="home" client:load />
  </body>
</html>
