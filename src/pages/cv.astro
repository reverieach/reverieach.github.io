    <div class="mb-5">
        <div class="text-3xl w-full font-bold">Education</div>
    </div>

    <div class="time-line-container grid gap-4 mb-10">
        <TimeLineElement
            title="B.Eng. in Artificial Intelligence"
            subtitle="[2023.09 - Present] Beijing University of Posts and Telecommunications"
        >
            School of Artificial Intelligence. Current work focuses on practical AI systems, computer vision, NLP, and automation tools.
        </TimeLineElement>
        <TimeLineElement
            title="High School"
            subtitle="[2020.09 - 2023.06] Tunxi No.1 High School, Huangshan"
        />
    </div>

    <div class="mb-5">
        <div class="text-3xl w-full font-bold">Selected Work</div>
    </div>

    <div class="time-line-container mb-10 grid gap-4">
        <TimeLineElement
            title="BUPT Homework Sentinel"
            subtitle="Python / Flask / Playwright / Windows Task Scheduler"
        >
            A local automation tool that checks unfinished BUPT ucloud homework and sends reminders through desktop, Markdown, WeChat, and email channels.
        </TimeLineElement>
        <TimeLineElement
            title="OW Translator Lite"
            subtitle="C# / OCR / Overlay / OpenAI-compatible APIs"
        >
            A lightweight real-time translation overlay designed for Overwatch foreign-server chat.
        </TimeLineElement>
        <TimeLineElement
            title="Embedded AI System on RK3568"
            subtitle="Python / NPU / Flask / Edge AI"
        >
            A course project integrating face recognition, LLM-style dialogue, and a PC-side management dashboard on an RK3568 board.
        </TimeLineElement>
    </div>

    <div class="mb-5">
        <div class="text-3xl w-full font-bold">Skills</div>
    </div>
    <ul class="list-disc mx-6 grid gap-2">
        <li>Python, TypeScript, C#, React/Astro, Flask</li>
        <li>Computer vision, OCR, PyTorch, edge inference</li>
        <li>NLP experiments, semantic matching, LLM-assisted workflows</li>
        <li>Desktop automation, GitHub Pages, practical tool design</li>
    </ul>
</BaseLayout>
